{
  "name": "move-in-inquiry-tool",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,ui -c blue,green \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "tsx watch server/dev-api.ts",
    "dev:ui": "vite",
    "dev:vercel": "vercel dev --listen 5173",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "db:setup": "tsx scripts/db-setup.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.5.14",
    "@vercel/node": "^5.1.8",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.3",
    "typescript": "~5.8.3",
    "vercel": "^41.6.0",
    "vite": "^6.3.5",
    "ws": "^8.18.1"
  }
}
